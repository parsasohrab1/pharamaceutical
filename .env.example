# HQCA runtime configuration
HQCA_LOG_LEVEL=INFO
HQCA_LOG_FORMAT=json
HQCA_RDKIT_LOGS=disabled

# Synthetic dataset generation
HQCA_RANDOM_SEED=2025
HQCA_NUM_PAIRS=500

# Output paths
HQCA_OUTPUT_CSV=output/hqca_synthetic_data.csv
HQCA_OUTPUT_JSON=output/hqca_synthetic_data.json
HQCA_METRICS_FILE=output/hqca_metrics.json
HQCA_REPORT_FILE=output/data_report.txt

# API/backend
HQCA_API_OUTPUT_DIR=output/api
HQCA_CORS_ORIGINS=http://localhost:5173
HQCA_MODEL_ARTIFACT=models/hqca_model.joblib

# Enterprise persistence and security
HQCA_DATABASE_URL=postgresql+psycopg://hqca:hqca@localhost:5432/hqca
HQCA_SECRET_KEY=change-me-in-production
# Optional Fernet key; when omitted, one is derived from HQCA_SECRET_KEY.
HQCA_ENCRYPTION_KEY=

# Object storage (MinIO-compatible). Leave empty to use local object storage.
HQCA_OBJECT_STORE_DIR=output/objects
HQCA_MINIO_ENDPOINT=localhost:9000
HQCA_MINIO_ACCESS_KEY=minioadmin
HQCA_MINIO_SECRET_KEY=minioadmin
HQCA_MINIO_BUCKET=hqca
HQCA_MINIO_SECURE=false

# Queue backend. Use "background" locally or "rq" with Redis workers.
HQCA_QUEUE_BACKEND=background
HQCA_REDIS_URL=redis://localhost:6379/0
HQCA_RQ_QUEUE=hqca
